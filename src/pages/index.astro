---
import Layout from "../layouts/Layout.astro";

const apps = [
  {
    name: "Orbit QR",
    subtitle: "QR Code Scanner & Generator",
    href: `${import.meta.env.BASE_URL}orbit-qr`,
  },
  {
    name: "Time Garden",
    subtitle: "Focus & Tasks",
    href: `${import.meta.env.BASE_URL}time-garden`,
  },
];

function initial(name: string) {
  return name.charAt(0).toUpperCase();
}
---

<Layout title="App Privacy Policies">
  <div class="not-prose min-h-screen bg-white px-6 py-12 max-w-2xl mx-auto">
    <header class="mb-10">
      <h1 class="text-2xl font-semibold text-gray-900 tracking-tight">
        App Privacy Policies
      </h1>
      <p class="mt-1 text-sm text-gray-500">
        Privacy policies for my mobile apps.
      </p>
    </header>

    <ul class="space-y-3">
      {
        apps.map((app) => (
          <li>
            <a
              href={app.href}
              class="flex items-center gap-4 rounded-xl border border-gray-200 bg-white px-5 py-4 hover:border-gray-300 hover:bg-gray-50 transition-colors group"
            >
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-gray-100 text-gray-600 font-semibold text-lg select-none group-hover:bg-gray-200 transition-colors">
                {initial(app.name)}
              </div>

              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate">
                  {app.name}
                </p>
                <p class="text-xs text-gray-500 truncate">{app.subtitle}</p>
              </div>

              <div class="flex items-center shrink-0">
                <svg
                  class="w-4 h-4 text-gray-400 group-hover:text-gray-600 transition-colors ml-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Layout>
